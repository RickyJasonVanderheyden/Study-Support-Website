# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/skilltracker?retryWrites=true&w=majority

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d

# Google Gemini AI (FREE)
GEMINI_API_KEY=your-free-gemini-api-key-here

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Email (SMTP) - used for Session Lead approval/rejection emails
# Example: Gmail SMTP -> EMAIL_HOST=smtp.gmail.com, EMAIL_PORT=587 (secure false) or 465 (secure true)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@example.com
EMAIL_PASS=your-email-app-password
# Optional (defaults to EMAIL_USER if omitted)
EMAIL_FROM=LearnLoop <your-email@example.com>
