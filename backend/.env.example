# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/skilltracker?retryWrites=true&w=majority

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d

# Google Gemini AI (FREE TIER - 15 RPM limit)
GEMINI_API_KEY=your-free-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash
# Rate limiting settings for FREE tier (15 RPM max)
GEMINI_RPM=10
GEMINI_MIN_DELAY_MS=6000
GEMINI_RETRY_ATTEMPTS=3
GEMINI_RATE_LIMIT_WAIT_MS=65000

# API rate limiting
API_WINDOW_MS=900000
API_MAX_REQUESTS=100
GENERATION_WINDOW_MS=86400000
GENERATION_MAX_REQUESTS=10

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
