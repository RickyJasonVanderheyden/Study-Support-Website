# Rate limiting settings for FREE tier (15 RPM max)
GEMINI_RPM=10
GEMINI_MIN_DELAY_MS=6000
GEMINI_RETRY_ATTEMPTS=3
GEMINI_RATE_LIMIT_WAIT_MS=65000

# API rate limiting
